---
import { experience } from '../data/experience'
---

<section id="experience" class="section" aria-label="Experience">
  <h2 class="section-label">experience</h2>
  <hr class="divider" />

  <div class="entries">
    {
      experience.map((entry, i) => (
        <div class="entry">
          <div>
            <span class="period muted">{entry.period}</span>
          </div>
          <div class="entry-body">
            <p class="role">
              <strong>{entry.role}</strong>
              <span class="muted"> — {entry.company}</span>
            </p>
            <ul class="bullets">
              {entry.bullets.map((b) => (
                <li>{b}</li>
              ))}
            </ul>
          </div>
          {i < experience.length - 1 && <hr class="divider entry-rule" />}
        </div>
      ))
    }
  </div>
</section>

<style>
  .entries {
    display: flex;
    flex-direction: column;
  }

  .entry {
    display: grid;
    grid-template-columns: 6rem 1fr;
    gap: 0 2rem;
    margin-bottom: 0;
  }

  .period {
    font-size: 0.8rem;
    white-space: nowrap;
  }

  .role {
    margin: 0 0 0.8rem;
  }

  .bullets {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .bullets li {
    padding-left: 1.25em;
    position: relative;
    color: var(--text);
    margin-bottom: 0.5rem;
    font-size: 0.9rem;
  }

  .bullets li::before {
    content: '—';
    position: absolute;
    left: 0;
    color: var(--muted);
  }

  .entry-rule {
    grid-column: 1 / -1;
  }

  @media (max-width: 560px) {
    .entry {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }
  }
</style>
