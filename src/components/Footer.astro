---
import { profile } from '../data/profile'

const year = new Date().getFullYear()
---

<footer class="footer">
  <hr class="divider" />
  <ul>
    <li>
      {profile.name.toLowerCase()} &mdash; {year}
      <span class="dot">&nbsp;&nbsp;&middot;</span>
    </li>
    <li>
      <a href={profile.social.github} target="_blank" rel="noopener">[github]</a>
    </li>

    <li>
      <a href={profile.social.linkedin} target="_blank" rel="noopener">[linkedin]</a>
    </li>
    <li>
      <a href={`mailto:${profile.social.email}`}>[email]</a>
    </li>
  </ul>
</footer>

<style>
  .footer {
    max-width: 760px;
    margin: 0 auto;
    padding: 0 2rem 3rem;
  }

  .footer ul {
    color: var(--muted);
    font-size: 0.85rem;
    display: flex;
    flex-direction: row;
    gap: 1rem;
  }

  @media (max-width: 640px) {
    .footer ul {
      flex-direction: column;
    }
    .dot {
      display: none;
    }
  }
</style>
