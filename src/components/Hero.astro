---
import { profile } from '../data/profile'
import { createRow, filledRow } from '../utils/ascii'

const bar = filledRow()

const artConfig: Array<null | { text: string; right?: boolean }> = [
  null,
  null,
  null,
  { text: profile.name },
  null,
  null,
  null,
  null,
  { text: profile.title, right: true },
  null,
  null,
  null,
]
---

<section class="hero" aria-labelledby="hero-heading">
  <div class="hero-inner">
    <div class="sr-only">
      <h1 id="hero-heading">{profile.name}</h1>
      <p>{profile.title}</p>
    </div>
    <div class="ascii-art" aria-hidden="true">
      {
        artConfig.map((config) => (
          <div class={`row${config?.right ? ' row-right' : ''}`}>
            {(config ? createRow(config) : bar).map(({ char, className }) => (
              <span class={className}>{char}</span>
            ))}
          </div>
        ))
      }
    </div>

    <script is:inline>
      {
        const coolChars = [
          '\u00bb', // »
          '\u2261', // ≡
          '~',
          '\u2534', // ┴
          '\u00a4', // ¤
          '/',
          '\u00b7', // ·
          '\u29bf', // ⦿
        ]
        const newChar = coolChars[Math.floor(Math.random() * coolChars.length)]
        document
          .querySelector('.ascii-art')
          .style.setProperty('--grid-char', `"${newChar}"`)
      }
    </script>

    <p class="tagline">{profile.tagline}</p>

    <div>
      <a href={profile.social.github} target="_blank" rel="noopener">[github]</a>
      <a href={profile.social.linkedin} target="_blank" rel="noopener">[linkedin]</a>
      <a href={`mailto:${profile.social.email}`}>[email]</a>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    padding: 10rem 2rem 4rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .hero-inner {
    width: 100%;
  }

  .row {
    display: flex;
    flex-wrap: wrap;
    height: 2.31rem; /* .ascii-art font-size (1.1rem) × line-height (2.1) */
    overflow: hidden;
    justify-content: space-evenly;
    cursor: none;
  }

  .row-right {
    flex-direction: row-reverse;
  }

  .ascii-art {
    font-family: 'Space Mono', 'Courier New', monospace;
    font-size: 1.1rem;
    line-height: 2.1;
    letter-spacing: 0.25cap;
    color: var(--text);
    margin: 0 0 3rem;
    user-select: none;
    touch-action: none;
  }

  .ascii-art span.grid::before {
    content: var(--grid-char, '');
  }

  .ascii-art span {
    display: inline-block;
    transition:
      color 2.5s ease-out,
      transform 2.5s ease-out;
  }

  .ascii-art span.text {
    font-weight: 700;
  }

  /* Grid spans: skip color transition — use ::after opacity instead (compositor-only, no repaint) */
  .ascii-art span.grid {
    transition: transform 2.5s ease-out;
    position: relative;
  }

  .ascii-art span.grid::after {
    content: var(--grid-char, '');
    position: absolute;
    left: 0;
    top: 0;
    color: var(--accent);
    font-weight: 700;
    opacity: 0;
    transition: opacity 2.5s ease-out;
  }

  .ascii-art span.grid:hover,
  .ascii-art span.grid.touched {
    font-weight: 700;
    transform: rotate(360deg) translateY(-25%) scale(1.4); /* grid chars */
    transition: transform 0.05s ease;
  }

  .ascii-art span.grid:hover::after,
  .ascii-art span.grid.touched::after {
    opacity: 1;
    transition: opacity 0.05s ease;
  }

  .ascii-art span.text:hover,
  .ascii-art span.text.touched {
    color: var(--accent);
    transform: rotate(3deg) translateY(-12%) scale(2.1); /* text chars */
    transition:
      color 0.05s ease,
      transform 0.05s ease;
  }

  .tagline {
    color: var(--muted);
    margin-bottom: 3rem;
  }

  @media (max-width: 640px) {
    .ascii-art {
      font-size: 0.825rem;
      line-height: 1.6;
      letter-spacing: 0.19cap;
    }

    .row {
      height: 1.3rem; /* 0.825rem × 1.6 */
    }

    .hero {
      padding-top: 5rem;
    }
  }
</style>

<script>
  const art = document.querySelector('.ascii-art') as HTMLElement | null
  if (art) {
    let current: HTMLElement | null = null
    let rafId: number | null = null

    function applyTouch(touch: Touch) {
      const el = document.elementFromPoint(touch.clientX, touch.clientY)
      if (
        el instanceof HTMLElement &&
        el.tagName === 'SPAN' &&
        art!.contains(el) &&
        el !== current
      ) {
        current?.classList.remove('touched')
        current = el
        el.classList.add('touched')
      }
    }

    art.addEventListener(
      'touchstart',
      (e) => {
        applyTouch(e.touches[0])
      },
      { passive: true }
    )

    art.addEventListener(
      'touchmove',
      (e) => {
        if (rafId !== null) return
        const touch = e.touches[0]
        rafId = requestAnimationFrame(() => {
          applyTouch(touch)
          rafId = null
        })
      },
      { passive: true }
    )

    art.addEventListener(
      'touchend',
      () => {
        if (rafId !== null) {
          cancelAnimationFrame(rafId)
          rafId = null
        }
        current?.classList.remove('touched')
        current = null
      },
      { passive: true }
    )
  }
</script>
